{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://raj-electrical-services.onrender.com/api/$1"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}